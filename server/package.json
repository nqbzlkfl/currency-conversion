{
  "name": "currency-converter-server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "APP_ENV=local dotenv -e env/.env.local -- tsx watch src/server.ts",
    "dev:preprod": "APP_ENV=preprod dotenv -e env/.env.preprod -- tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "start:local": "APP_ENV=local dotenv -e env/.env.local -- tsx src/server.ts",
    "start:preprod": "APP_ENV=preprod dotenv -e env/.env.preprod -- tsx src/server.ts",
    "start:prod": "APP_ENV=prod dotenv -e env/.env.prod -- tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
