# Backend environment variables — TEMPLATE
# Copy this file to .env.local / .env.preprod / .env.prod and fill in real values.
# The actual env files are gitignored.

# ── Required ────────────────────────────────────────────────────────────────

# Open Exchange Rates App ID. Server fails to start if missing.
OXR_APP_ID=

# ── Optional (sensible defaults shown) ──────────────────────────────────────

# HTTP listen port
PORT=8800

# Upstream API base URL (no trailing slash)
OXR_BASE_URL=https://openexchangerates.org/api

# Cache TTL for /latest.json — OXR free plan updates hourly
RATES_TTL_MS=3600000

# Cache TTL for /currencies.json — list rarely changes
CURRENCIES_TTL_MS=86400000

# CORS origin. Use the frontend's origin in preprod/prod, * in local
CORS_ORIGIN=*

# Log level: error | warn | info | debug
LOG_LEVEL=info
