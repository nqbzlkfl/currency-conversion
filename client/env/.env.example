# Frontend environment variables — TEMPLATE
# Copy this to .env.local / .env.preprod / .env.prod and adjust as needed.
# Real env files are gitignored.

# When true, services/api.ts uses local mock data instead of calling the
# backend. Useful when developing without the server running.
# Default is false so the app hits the real backend out of the box.
VITE_USE_MOCK=false

# Backend API base URL.
# - Local dev: keep as /api (Vite proxies it to localhost:8800)
# - Preprod / prod: full https://... URL of the deployed backend
VITE_API_BASE_URL=/api
